{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@types/*": ["types/*"],
      "@utils/*": ["utils/*"],
      "@pages/*": ["pages/*"],
      "@agents/*": ["agents/*"]
    }
  },
  "include": [
    "agents/**/*.ts",
    "pages/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.ts",
    "utils/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests/generated/.gitkeep"
  ]
}
