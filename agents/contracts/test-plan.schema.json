{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TestPlan",
  "type": "object",
  "required": ["planId", "timestamp", "sourceAnalysisId", "scenarios"],
  "properties": {
    "planId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "sourceAnalysisId": { "type": "string" },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "scenarioId",
          "title",
          "priority",
          "module",
          "testType",
          "preconditions",
          "steps",
          "expectedOutcome"
        ],
        "properties": {
          "scenarioId": { "type": "string" },
          "title": { "type": "string" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "module": {
            "type": "string",
            "enum": ["auth", "products", "cart", "contact", "home"]
          },
          "testType": {
            "type": "string",
            "enum": ["smoke", "regression", "negative", "edge"]
          },
          "preconditions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "steps": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expectedOutcome": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "totalScenarios": { "type": "number" },
    "coverageNotes": { "type": "string" }
  }
}
