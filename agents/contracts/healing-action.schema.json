{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HealingAction",
  "type": "object",
  "required": ["healingId", "timestamp", "sourceAnalysisId", "actions"],
  "properties": {
    "healingId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "sourceAnalysisId": { "type": "string" },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "testId",
          "filePath",
          "actionType",
          "description",
          "applied",
          "confidence"
        ],
        "properties": {
          "testId": { "type": "string" },
          "filePath": { "type": "string" },
          "backupPath": { "type": "string" },
          "actionType": {
            "type": "string",
            "enum": [
              "selector_update",
              "timeout_increase",
              "wait_added",
              "assertion_adjusted",
              "skipped_low_confidence",
              "skipped_app_bug"
            ]
          },
          "description": { "type": "string" },
          "before": { "type": "string" },
          "after": { "type": "string" },
          "applied": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "skipReason": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "totalAttempted": { "type": "number" },
        "totalApplied": { "type": "number" },
        "totalSkipped": { "type": "number" }
      }
    }
  }
}
