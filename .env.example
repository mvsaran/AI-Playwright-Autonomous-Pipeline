# ─────────────────────────────────────────────
# AI Playwright Autonomous Pipeline
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# OpenAI API Key (required for all AI agents)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Maximum tokens per AI call
OPENAI_MAX_TOKENS=4096

# Temperature for AI responses (0.0 = deterministic, 1.0 = creative)
OPENAI_TEMPERATURE=0.2

# Target application URL
BASE_URL=https://automationexercise.com

# Playwright settings
HEADLESS=true
SLOW_MO=0

# Pipeline quality gate thresholds
PASS_THRESHOLD=80
WARN_THRESHOLD=60

# Paths (relative to project root)
AGENTS_OUTPUT_DIR=agents/output
REPORTS_DIR=reports
ARTIFACTS_DIR=artifacts
TESTS_GENERATED_DIR=tests/generated

# Run label (used in reports)
RUN_LABEL=local-run

# Self-Healer safety switch
# Set to false to stage AI fix suggestions in the report WITHOUT patching source files.
# Useful for review-before-apply workflows. Default: true (files are patched automatically)
AI_AUTO_HEAL=true
