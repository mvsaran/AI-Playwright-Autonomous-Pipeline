    "ai:bootstrap": "tsx scripts/bootstrap.ts",
    "prepare": "tsx scripts/prepare-folders.ts"
  },
  "dependencies": {
    "openai": "^4.47.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.12",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
